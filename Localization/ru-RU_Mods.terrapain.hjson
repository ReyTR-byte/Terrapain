Items: {
	TheSwordOfSpeed: {
		DisplayName: Меч скорости
		Tooltip:
			'''
			Этот меч увеличивает свою скорость с каждой атакой
			Если перестать атаковать меч потеряет свою скорость
			Если выкинуть мечь он потеряет свою скорость моментально
			'''
	}

